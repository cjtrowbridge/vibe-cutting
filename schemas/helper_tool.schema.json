{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Callable Helper Tool Adapter",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "display_name",
    "tool_class",
    "source",
    "capabilities",
    "routing",
    "runtime",
    "outputs",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "tool_class": {
      "const": "callable_helper"
    },
    "source": {
      "type": "object",
      "required": [
        "type",
        "path",
        "upstream",
        "pinned_revision",
        "license",
        "license_file"
      ],
      "properties": {
        "type": {
          "const": "git_submodule"
        },
        "path": {
          "type": "string",
          "pattern": "^third_party/"
        },
        "upstream": {
          "type": "string",
          "format": "uri"
        },
        "pinned_revision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "license_file": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "routing": {
      "type": "object",
      "required": ["use_for", "avoid_for"],
      "properties": {
        "use_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "avoid_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": [
        "kind",
        "python_minimum",
        "module",
        "install_source",
        "environment_path",
        "working_directory"
      ],
      "properties": {
        "kind": {
          "const": "python_module"
        },
        "python_minimum": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "module": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$"
        },
        "install_source": {
          "type": "string",
          "pattern": "^third_party/"
        },
        "environment_path": {
          "type": "string",
          "pattern": "^\\.tmp/helper-tools/"
        },
        "working_directory": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "outputs": {
      "type": "object",
      "required": ["accepted_formats", "primary_format", "operation_colors"],
      "properties": {
        "accepted_formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "primary_format": {
          "type": "string"
        },
        "operation_colors": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": [
        "controls_hardware",
        "setup_may_use_network",
        "may_modify_source",
        "allowed_output_roots"
      ],
      "properties": {
        "controls_hardware": {
          "const": false
        },
        "setup_may_use_network": {
          "type": "boolean"
        },
        "may_modify_source": {
          "const": false
        },
        "allowed_output_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
