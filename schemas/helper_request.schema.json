{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Helper Tool Request",
  "type": "object",
  "required": ["schema_version", "tool_id", "request_type", "inputs", "outputs"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "tool_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "request_type": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parameters": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
