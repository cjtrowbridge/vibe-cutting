{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Helper Tool Result",
  "type": "object",
  "required": [
    "schema_version",
    "tool_id",
    "request_hash",
    "status",
    "provenance",
    "outputs"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "tool_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "request_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "status": {
      "enum": ["ok", "failed", "blocked"]
    },
    "provenance": {
      "type": "object",
      "required": ["source_revision", "adapter_sha256", "environment_fingerprint"],
      "properties": {
        "source_revision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "adapter_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "environment_fingerprint": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "runtime_versions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "lock_hashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      },
      "additionalProperties": false
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "format", "sha256"],
        "properties": {
          "path": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "additionalProperties": false
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
