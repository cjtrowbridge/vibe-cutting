{
  "schema_version": 2,
  "id": "bosl2",
  "display_name": "BOSL2 OpenSCAD",
  "tool_class": "callable_helper",
  "source": {
    "type": "git_submodule",
    "path": "third_party/bosl2",
    "upstream": "https://github.com/BelfrySCAD/BOSL2",
    "pinned_revision": "fbcdfdd511b6abfde93c43c8f85c2bd24ee7a02d",
    "license": "BSD-2-Clause",
    "license_file": "LICENSE"
  },
  "capabilities": [
    "openscad_library",
    "spur_gears",
    "ring_gears",
    "rack_gears",
    "comparison_geometry",
    "svg_geometry"
  ],
  "routing": {
    "use_for": [
      "OpenSCAD-based comparison profiles for spur gears, ring gears, and racks",
      "Fallback geometry checks against another OpenSCAD gear implementation",
      "Reviewing BOSL2 gear behavior without changing user-global OpenSCAD configuration"
    ],
    "avoid_for": [
      "Authoritative mechanism validation",
      "Machine recipes, G-code, hardware control, or fabrication approval",
      "Non-planar gears or generated geometry requiring 3D stack validation"
    ]
  },
  "provider": {
    "kind": "openscad_library",
    "environment_path": ".tools/environments/bosl2",
    "working_directory": ".",
    "setup": {
      "cache_path": ".tools/cache/helpers/bosl2",
      "temp_path": ".tools/tmp/helpers/bosl2",
      "log_path": ".tools/logs/helpers/bosl2",
      "staging_path": ".tools/staging/helpers/bosl2"
    },
    "invocation": {
      "driver": "setup/tools/bosl2.py",
      "executable": "openscad",
      "mode": "openscad_svg"
    },
    "version": {
      "openscad_minimum": "2021.01"
    }
  },
  "outputs": {
    "accepted_formats": [
      "svg",
      "json"
    ],
    "primary_format": "svg",
    "operation_colors": {
      "rgb(0,0,0)": "comparison_profile"
    },
    "inventory": []
  },
  "safety": {
    "controls_hardware": false,
    "setup_may_use_network": false,
    "may_modify_source": false,
    "allowed_input_roots": [
      ".tmp",
      "designs"
    ],
    "allowed_output_roots": [
      ".tmp",
      "output",
      "revisions"
    ]
  },
  "readiness": {
    "states": [
      "registered",
      "dependencies-ready",
      "invocation-ready",
      "output-validated"
    ],
    "fabrication_approved": false
  }
}
